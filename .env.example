# Longbridge OAuth 2.0
# The first run prints an authorization URL. The SDK caches the OAuth token.
LONGBRIDGE_CLIENT_ID=your_oauth_client_id

# Dashboard binds to localhost by default. Set this only when LAN access is intentional.
# QQQ_DASHBOARD_HOST=0.0.0.0

# Optional notification secrets. Environment values override settings.json.
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Optional GitHub Gist synchronization
GIST_ID=your_gist_id
GITHUB_TOKEN=ghp_your_token

# Optional Feishu notification credentials
# FEISHU_APP_ID=your_app_id
# FEISHU_APP_SECRET=your_app_secret
